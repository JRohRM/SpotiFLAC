# ── SpotiFLAC server configuration ───────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Bearer token for API authentication.
# Generate one with: openssl rand -hex 32
API_TOKEN=change_me_to_a_long_random_string

# Host path to your Navidrome music folder.
# This is the directory on the SERVER (not inside the container).
MUSIC_DIR=/path/to/your/navidrome/music

# Path inside the container (should match the volume target above).
OUTPUT_DIR=/music

# Your server's public domain name (used by Traefik).
DOMAIN=your.domain.com

# Traefik cert resolver name (check your Traefik config).
CERT_RESOLVER=letsencrypt

# Port the Go server listens on inside the container (usually no need to change).
PORT=8080
